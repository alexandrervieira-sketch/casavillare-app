rules_version = '2';

// Casa Villare — Storage (anexos dos leads: fotos, PDFs, projetos)
// Só membros da equipe AUTENTICADOS (Firebase Auth) leem/gravam. Limite de 30 MB por arquivo.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.size < 30 * 1024 * 1024;
    }
  }
}
