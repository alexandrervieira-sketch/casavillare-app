rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Casa Villare — ERP interno · Regras de segurança do Firestore
//
// BASELINE: nada é público. Só membros AUTENTICADOS com e-mail do DOMÍNIO
// CORPORATIVO (@casavillare.com.br) leem/escrevem. (C1, 14/07/2026: antes bastava
// `request.auth != null` — como o auto-cadastro Email/Senha é aberto, qualquer um
// da internet podia criar conta e ler/gravar leads, cadastros (CPF), pedidos.
// A restrição de domínio era só no cliente. Agora é imposta no servidor.)
//
// Perfil vem do custom claim `request.auth.token.perfil` (carimbado via _set_claims.js).
//   - Financeiras (dre, folhas, comissoes, vendasCom): leitura E escrita gestor OU financeiro.
//   - _config/configs e _config/equipe: escrita só gestor. _cfgpriv (salários): leitura
//     gestor/financeiro, escrita só gestor. _audit: leitura só gestor, sem update/delete.
//
// (OPCIONAL, mais forte) exigir e-mail verificado: descomente a linha email_verified
// em corporativo(). ANTES, confirme no Console › Auth que as contas têm email_verified=true.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    // Só e-mail corporativo. `matches` faz full-match; ^...$ reforça; (?i) case-insensitive.
    function corporativo() {
      return request.auth != null
        && request.auth.uid != null
        && request.auth.token.email != null
        // && request.auth.token.email_verified == true   // (opcional, ver cabeçalho)
        && request.auth.token.email.matches('(?i)^[^@]+@casavillare[.]com[.]br$');
    }
    function autenticado() {
      return corporativo();
    }
    function isGestor() {
      return autenticado() && request.auth.token.perfil == 'gestor';
    }
    function isFinanceiro() {
      return autenticado() && request.auth.token.perfil == 'financeiro';
    }
    function podeFinanceiro() {
      return isGestor() || isFinanceiro();
    }
    function isFinanceira(c) {
      return c == 'dre' || c == 'folhas' || c == 'comissoes' || c == 'vendasCom';
    }

    // ── Trilha de auditoria: leitura só gestor; cria sim; edita/apaga NUNCA ──
    match /_audit/{doc} {
      allow read:   if isGestor();
      allow create: if autenticado();
      allow update, delete: if false;
    }

    // ── Config: leitura p/ qualquer autenticado; escrita só gestor p/ configs/equipe ──
    match /_config/{doc} {
      allow read:  if autenticado();
      allow write: if autenticado() && ( (doc != 'configs' && doc != 'equipe') || isGestor() );
    }

    // ── Dados sensíveis (salário/CPF): leitura gestor+financeiro; escrita só gestor ──
    match /_cfgpriv/{doc} {
      allow read:  if podeFinanceiro();
      allow write: if isGestor();
    }

    // ── Demais coleções: financeiras só gestor/financeiro; resto, corporativo ──
    match /{collection}/{doc} {
      allow read:  if collection != '_audit' && collection != '_config' && collection != '_cfgpriv' && autenticado() && (isFinanceira(collection) ? podeFinanceiro() : true);
      allow write: if collection != '_audit' && collection != '_config' && collection != '_cfgpriv' && autenticado() && (isFinanceira(collection) ? podeFinanceiro() : true);
    }
  }
}
