rules_version = '2';

// ─────────────────────────────────────────────────────────────────────────────
// Casa Villare — ERP interno · Regras de segurança do Firestore
//
// BASELINE: nada é público. Só membros AUTENTICADOS (Firebase Auth) leem/escrevem.
//
// P0-4 FASE 1 (permissões por perfil no servidor):
//   - O perfil vem do custom claim `request.auth.token.perfil` (carimbado via Admin).
//   - Coleções financeiras (dre, folhas, comissoes, vendasCom): leitura E escrita
//     para gestor OU financeiro. As demais (leads, pedidos, agenda, cadastros, _config…)
//     seguem para qualquer autenticado.
//   - _audit: leitura SÓ gestor; create por qualquer autenticado (o app registra);
//     update/delete NUNCA (trilha inviolável).
//
// Obs.: regra ÚNICA por coleção (sem match permissivo concorrente) — no Firestore,
// se QUALQUER match concede, o acesso é concedido; então o genérico já embute a
// restrição, em vez de um match restritivo "por cima".
//
// FASE 2 (futura): mover salários/tabelas (_config/configs, _config/configsCom)
// para coleção própria gestor-only; exclusão só-gestor; _audit à prova de forja.
// ─────────────────────────────────────────────────────────────────────────────

service cloud.firestore {
  match /databases/{database}/documents {

    function autenticado() {
      return request.auth != null && request.auth.uid != null;
    }
    function isGestor() {
      return autenticado() && request.auth.token.perfil == 'gestor';
    }
    function isFinanceiro() {
      return autenticado() && request.auth.token.perfil == 'financeiro';
    }
    // Quem pode ler/escrever as coleções financeiras: gestor OU financeiro
    function podeFinanceiro() {
      return isGestor() || isFinanceiro();
    }
    function isFinanceira(c) {
      return c == 'dre' || c == 'folhas' || c == 'comissoes' || c == 'vendasCom';
    }

    // ── Trilha de auditoria: leitura só gestor; cria sim; edita/apaga NUNCA ──
    match /_audit/{doc} {
      allow read:   if isGestor();
      allow create: if autenticado();
      allow update, delete: if false;
    }

    // ── Config: leitura p/ qualquer autenticado (o app precisa de equipe/permissões).
    //    Escrita: qualquer autenticado, EXCETO os docs 'configs' (perfil, permissões,
    //    salários) e 'equipe' (papéis), que são SÓ GESTOR. Fecha a escalada de
    //    privilégio (não-gestor reescrevendo o próprio perfil pelo DevTools).
    //    Os demais docs de _config (_tomb, tabelaCartao, tabelaFinanciamento,
    //    bipartido…) continuam abertos p/ o sync de todos funcionar.
    //    (O cliente não empurra configs/equipe quando não é gestor — ver _fsConfigDocs.)
    match /_config/{doc} {
      allow read:  if autenticado();
      allow write: if autenticado() && ( (doc != 'configs' && doc != 'equipe') || isGestor() );
    }

    // ── Dados sensíveis do colaborador (salário, adiantamento, CPF/RG): leitura
    //    só gestor+financeiro; escrita só gestor. Coleção PRÓPRIA (não em _config)
    //    porque uma consulta de coleção é negada por inteiro se um doc dela for
    //    ilegível — o que travaria o _config de todos. (E1) ──
    match /_cfgpriv/{doc} {
      allow read:  if podeFinanceiro();
      allow write: if isGestor();
    }

    // ── Demais coleções: financeiras só gestor/financeiro; resto, autenticado ──
    match /{collection}/{doc} {
      allow read:  if collection != '_audit' && collection != '_config' && collection != '_cfgpriv' && autenticado() && (isFinanceira(collection) ? podeFinanceiro() : true);
      allow write: if collection != '_audit' && collection != '_config' && collection != '_cfgpriv' && autenticado() && (isFinanceira(collection) ? podeFinanceiro() : true);
    }
  }
}
