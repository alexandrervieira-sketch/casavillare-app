{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "node_modules/**",
      "*.pptx",
      "*.pdf"
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
