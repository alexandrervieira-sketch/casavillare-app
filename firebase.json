{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "netlify.toml",
      "netlify/**",
      "functions/**",
      "node_modules/**",
      "*.pptx",
      "*.pdf"
    ],
    "rewrites": [
      { "source": "/api/nfe-emit", "function": "nfeEmit" }
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ]
  },
  "functions": {
    "source": "functions",
    "runtime": "nodejs18"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  }
}
